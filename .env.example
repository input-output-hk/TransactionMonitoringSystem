# ── Cardano ───────────────────────────────────────────────────────────────────
CARDANO_NETWORK=preprod          # mainnet | preprod

# ── Ogmios ────────────────────────────────────────────────────────────────────
OGMIOS_WS_URL=ws://localhost:1337
OGMIOS_RECONNECT_MAX_DELAY=60          # max backoff delay in seconds
OGMIOS_HEARTBEAT_INTERVAL=30           # ping interval in seconds
OGMIOS_HEARTBEAT_TIMEOUT=90            # pong timeout in seconds
OGMIOS_CIRCUIT_BREAKER_THRESHOLD=5     # consecutive failures before cooldown
OGMIOS_CIRCUIT_BREAKER_COOLDOWN=120    # cooldown duration in seconds

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── API Key Authentication ────────────────────────────────────────────────────
# Comma-separated list of valid keys. Empty = open access (dev mode, logged as warning).
API_KEYS=
# API_KEY_HEADER=TMS-API-Key    # default: TMS-API-Key

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60           # max requests per window per key
RATE_LIMIT_WINDOW_SECONDS=60

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tms_user
POSTGRES_PASSWORD=tms_password
POSTGRES_DB=tms_db

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=tms_analytics

# ── Raw Transaction Store ─────────────────────────────────────────────────────
# Local filesystem path for gzip-compressed raw Ogmios JSON blobs.
# Path structure: {RAW_STORE_PATH}/{confirmed|mempool}/{network}/{YYYYMMDD}/{tx_hash[:2]}/{tx_hash}.json.gz
# Upgrade path: MinIO (production Docker Compose) → S3/R2/B2 (Mainnet).
RAW_STORE_PATH=./data/raw
RAW_STORE_ENABLED=true

# ── Analysis Engine ───────────────────────────────────────────────────────────
ANALYSIS_ENGINE_ENABLED=true
ANALYSIS_ENGINE_INTERVAL_SECONDS=30
ANALYSIS_ENGINE_BATCH_SIZE=100
ANALYSIS_ENGINE_VERSION=mock-v1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
