# Template for the shared `.env` file.
#
#   cp .env.example .env
#
# Secrets (API keys, DB passwords) go in `.env`, which is gitignored.
# Do NOT put secrets in this file — it is tracked in git.
#
# Per-network values (CARDANO_NETWORK, OGMIOS_WS_URL, API_PORT) live in
# .env.preprod / .env.preview / .env.<name> (also gitignored) and are
# selected at launch via TMS_ENV=<name>. Defaults to preprod when unset.

# ── Selected Network ───────────────────────────────────────────────
# Determines which network-specific env file is selected when using the app profile.
# Defaults to preprod when unset.
TMS_ENV=preprod

# ── Ogmios tuning (shared) ────────────────────────────────────────────────────
OGMIOS_RECONNECT_MAX_DELAY=60          # max backoff delay in seconds
OGMIOS_HEARTBEAT_INTERVAL=30           # ping interval in seconds
OGMIOS_HEARTBEAT_TIMEOUT=90            # pong timeout in seconds
OGMIOS_CIRCUIT_BREAKER_THRESHOLD=5     # consecutive failures before cooldown
OGMIOS_CIRCUIT_BREAKER_COOLDOWN=120    # cooldown duration in seconds

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
# API_PORT is set per-network (see .env.preprod, .env.preview)

# ── API Key Authentication ────────────────────────────────────────────────────
# Comma-separated list of valid keys. Set this in production.
# If left empty, the app refuses to start unless TMS_ALLOW_DEV_MODE=1
# is also set (see below). This guard prevents an accidental production
# deploy from silently running an open API.
API_KEYS=
# API_KEY_HEADER=TMS-API-Key    # default: TMS-API-Key
# TMS_ALLOW_DEV_MODE=1          # required to run with empty API_KEYS

# ── Frontend Build (Vite) ─────────────────────────────────────────────────────
# Baked into the SPA bundle by the frontend-build stage in backend/Dockerfile.
# Browser auth is the magic-link session cookie set by /api/auth/verify —
# no API key is shipped to the client. API_KEYS above is for server-to-server
# callers (CLI, integrations) only.
VITE_NETWORK=preprod

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=240          # max requests per window per key
RATE_LIMIT_WINDOW_SECONDS=60

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tms_user
POSTGRES_PASSWORD=tms_password
POSTGRES_DB=tms_db

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=tms_analytics

# ── Raw Transaction Store ─────────────────────────────────────────────────────
# Local filesystem path for gzip-compressed raw Ogmios JSON blobs.
# Path structure: {RAW_STORE_PATH}/{confirmed|mempool}/{network}/{YYYYMMDD}/{tx_hash[:2]}/{tx_hash}.json.gz
# Upgrade path: MinIO (production Docker Compose) → S3/R2/B2 (Mainnet).
RAW_STORE_PATH=./data/raw
RAW_STORE_ENABLED=true

# ── Analysis Engine ───────────────────────────────────────────────────────────
ANALYSIS_ENGINE_ENABLED=true
ANALYSIS_ENGINE_INTERVAL_SECONDS=30
ANALYSIS_ENGINE_BATCH_SIZE=100
ANALYSIS_ENGINE_VERSION=mock-v1

# ── Magic-link auth ───────────────────────────────────────────────────────────
# Sessions are opaque IDs (NOT JWTs) backed by Postgres rows. The cookie
# is HTTP-only + SameSite=Lax + Secure (auto-detected behind a TLS proxy).
SESSION_COOKIE_NAME=tms_session
SESSION_TTL_DAYS=7
MAGIC_LINK_TTL_MINUTES=15
# Used to build the verification URL inside outgoing magic-link emails.
# Point this at the public URL of the SPA in prod (e.g. https://tms.example.com).
APP_BASE_URL=http://localhost:8000

# ── SMTP (magic-link delivery) ────────────────────────────────────────────────
# Dev: docker compose ships a Mailpit catch-all at mailpit:1025 (web UI on
# :8025) — every email sent is captured and viewable, never forwarded.
# Prod: replace these with the customer's SMTP provider.
SMTP_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false       # implicit TLS (port 465 style)
SMTP_USE_STARTTLS=false  # opportunistic STARTTLS upgrade
SMTP_FROM_EMAIL=noreply@tms.local
SMTP_FROM_NAME=TMS

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
