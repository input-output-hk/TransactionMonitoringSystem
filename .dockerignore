# Version control
.git/
.gitignore

# Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Runtime data — never bake into image
backend/data/
backend/data/rocksdb/

# Environment files — secrets must not be baked in
.env
*.env
.env.*
!.env.example

# Development tooling
**/.venv/
**/venv/
**/.tox/
**/node_modules/

# Docs and test artefacts
docs/
**/*.md
**/tests/
**/test_*.py

# The clustering module has its OWN build context (services/clustering/backend);
# it must not bloat the `app` image, whose build context is the repo root.
services/clustering/

# Editor / OS
.DS_Store
**/.idea/
**/.vscode/
