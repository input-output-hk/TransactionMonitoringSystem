# Per-network overrides for the Cardano preprod testnet.
#
# Copy this template to .env.preprod and edit OGMIOS_WS_URL, then launch with
# TMS_ENV=preprod. These values are layered on top of the shared .env (later
# wins); shell environment variables win over both.
#
# .env.preprod itself is gitignored; only this .example template is tracked.

CARDANO_NETWORK=preprod
# Your preprod Ogmios v6 endpoint. The bundled local stack (--profile ingestion)
# serves Ogmios at ws://localhost:1337.
OGMIOS_WS_URL=ws://localhost:1337
API_PORT=8000

# Kupo (address index) for on-demand historical backfill of a contract whose
# activity predates this node's sync start. Leave empty to disable backfill
# (POST /api/v1/backfill returns 503). The --profile ingestion stack serves Kupo
# at http://kupo:1442 (in-network) / http://localhost:1442 (host).
KUPO_URL=
# Where Kupo starts indexing: 'origin' for the full chain (needed to backfill an
# OLD contract's complete history), or 'SLOT.HEADERHASH' to index only from a
# recent point (far cheaper when recent history is enough).
KUPO_SINCE=origin
