# Per-network overrides for the Cardano preview testnet.
#
# Copy this template to .env.preview and edit OGMIOS_WS_URL, then launch with
# TMS_ENV=preview. These values are layered on top of the shared .env (later
# wins); shell environment variables win over both.
#
# .env.preview itself is gitignored; only this .example template is tracked.

CARDANO_NETWORK=preview
OGMIOS_WS_URL=ws://localhost:1337
API_PORT=8001
